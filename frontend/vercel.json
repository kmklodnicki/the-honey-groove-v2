{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "node node_modules/@craco/craco/dist/bin/craco.js build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
